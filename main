import asyncio, os, time, json
from google import genai
import aiosqlite
from dotenv import load_dotenv
from aiogram import Bot, Dispatcher
from aiogram.types import Message
from aiogram.filters import Command
from pydantic import BaseModel
from typing import List
from desc import CHARACTERS, STORY_STAGES

load_dotenv()
teller = Bot(token=os.getenv("BOT0"))
bot1 = Bot(token=os.getenv("BOT1"))
bot2 = Bot(token=os.getenv("BOT2"))
bot3 = Bot(token=os.getenv("BOT3"))

dp = Dispatcher()

# Створюємо під-модель для однієї репліки
class BotReply(BaseModel):
    bot_id: str        # Формат: "bot_123456789" (реальний ID бота, як вказано у промпті)
    text: str

# Оновлюємо головну модель
class GameResponse(BaseModel):
    replies: List[BotReply]
    new_facts: List[str]
    scene_goal_reached: bool  # НОВЕ ПОЛЕ ДЛЯ ШІ

client = genai.Client(api_key=os.getenv("GEMINI_API_KEY"))

# 1. Оновлюємо структуру БД: додаємо message_id і UNIQUE
async def init_db():
    async with aiosqlite.connect("chat_history.db") as db:
        # Таблиця повідомлень (вже існує)
        await db.execute("""
            CREATE TABLE IF NOT EXISTS messages (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                chat_id INTEGER,
                message_id INTEGER,
                sender TEXT,
                text TEXT,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                UNIQUE(chat_id, message_id)
            )
        """)
        # Нова таблиця для фактів про користувача
        await db.execute("""
            CREATE TABLE IF NOT EXISTS memories (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                chat_id INTEGER,
                fact TEXT,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        """)
        # Нова таблиця для відстеження сюжету
        await db.execute("""
            CREATE TABLE IF NOT EXISTS chat_states (
                chat_id INTEGER PRIMARY KEY,
                current_stage INTEGER DEFAULT 1
            )
        """)
        await db.commit()

async def get_chat_stage(db: aiosqlite.Connection, chat_id: int):
    async with db.execute("SELECT current_stage FROM chat_states WHERE chat_id = ?", (chat_id,)) as cursor:
        row = await cursor.fetchone()
        return row[0] if row else 1

async def advance_chat_stage(db: aiosqlite.Connection, chat_id: int):
    await db.execute("INSERT INTO chat_states (chat_id, current_stage) VALUES (?, 2) ON CONFLICT(chat_id) DO UPDATE SET current_stage = current_stage + 1", (chat_id,))
    await db.commit()

# Функція для збереження нового факту
async def save_fact(db: aiosqlite.Connection, chat_id: int, fact: str):
    await db.execute("INSERT INTO memories (chat_id, fact) VALUES (?, ?)", (chat_id, fact))
    await db.commit()

# Функція для отримання всіх знаних фактів про користувача
async def get_user_memories(db: aiosqlite.Connection, chat_id: int):
    async with db.execute("SELECT fact FROM memories WHERE chat_id = ?", (chat_id,)) as cursor:
        rows = await cursor.fetchall()
        return [row[0] for row in rows]


async def get_chat_history(db: aiosqlite.Connection, chat_id: int, limit: int = 10):
    async with db.execute(
        "SELECT sender, text FROM messages WHERE chat_id = ? ORDER BY created_at DESC LIMIT ?",
        (chat_id, limit)
    ) as cursor:
        rows = await cursor.fetchall()
        return rows[::-1]


async def generate_and_send_response(db: aiosqlite.Connection, chat_id: int, bot1_id: int, bot2_id: int, bot3_id: int):
    # Використовуємо передане з'єднання (db)
    history = await get_chat_history(db, chat_id, limit=15)
    existing_memories = await get_user_memories(db, chat_id)
    current_stage = await get_chat_stage(db, chat_id)
    stage_info = STORY_STAGES.get(current_stage, {"title": "Вільна гра", "context": "Просто спілкування.", "goal": "Немає"})

    prompt = f"""
    ТИ — РЕЖИСЕР DARK ROMANCE ГРИ "АКАДЕМІЯ СВЯТОГО ЮДИ".
    ПОТОЧНА СЮЖЕТНА ГЛАВА: {stage_info['title']}
    КОНТЕКСТ СЦЕНИ: {stage_info['context']}
    МЕТА СЦЕНИ (ДЛЯ РЕЖИСЕРА, АЛЕ ПРИХОВАНА ВІД БОТІВ): {stage_info['goal']}

    ПЕРСОНАЖІ (ЇХНІЙ СТИЛЬ ТА ОСОБИСТІ МОТИВИ):
    - bot_{bot1_id} (Кай). СТИЛЬ: {CHARACTERS['kai']['style']} | ОСОБИСТА МЕТА: {CHARACTERS['kai']['goal']}
    - bot_{bot2_id} (Доріан). СТИЛЬ: {CHARACTERS['dorian']['style']} | ОСОБИСТА МЕТА: {CHARACTERS['dorian']['goal']}
    - bot_{bot3_id} (Люціан). СТИЛЬ: {CHARACTERS['lucian']['style']} | ОСОБИСТА МЕТА: {CHARACTERS['lucian']['goal']}
    
    ДОСЬЄ ГРАВЦЯ (user):
    {existing_memories}
    
    ДІАЛОГ:
    {history}
    
    🔥 КРИТИЧНІ ПРАВИЛА СПІЛКУВАННЯ (СУВОРО) 🔥:
    1. ЗАБОРОНА НА УЛЬТИМАТУМИ: Персонажі НЕ ПОВИННІ вимагати вибору в кожному повідомленні. 
    2. ЕМОЦІЙНА РЕАКЦІЯ ЧЕРЕЗ ПРИЗМУ МЕТИ: Реагуйте на слова гравця (навіть на крапки чи мати), спираючись на ОСОБИСТУ МЕТУ персонажа. Доріан має сприймати зухвалість як виклик його владі, Кай — як сигнал, що гравця треба захистити.
    3. ЖИВИЙ ДІАЛОГ: Відповідайте природно (1-3 речення). Спочатку реакція на слова гравця, потім — дія за характером.
    4. ЕФЕКТ РЕВНОЩІВ: Кай і Доріан коментують репліки один одного.
    5. СУВОРЕ ПРАВИЛО ЛЮЦІАНА: Він пише ЛИШЕ тоді, коли user прямо звертається до нього. 
    6. ВІДПОВІДІ (REPLY): Якщо в тексті user є "(Примітка: це пряма відповідь на повідомлення від...)", цей бот ПОВИНЕН відповісти їй першим.
    
    ПРАВИЛО ПАМ'ЯТІ (new_facts):
    Записуй ТІЛЬКИ факти про ГРАВЦЯ.
    
    ПРАВИЛО СЮЖЕТУ:
    Оціни, чи досягнута "МЕТА СЦЕНИ". Став `scene_goal_reached` = true ТІЛЬКИ якщо рішення гравця ПРЯМЕ І ОСТАТОЧНЕ. Інакше — false.
    """
    
    response = await client.aio.models.generate_content(
        model='gemini-3.1-flash-lite',
        contents=prompt,
        config={
            'response_mime_type': 'application/json',
            'response_schema': GameResponse,
        }
    )
    
    try:
        # Безпечний спосіб: використовуємо вже розпарсений SDK об'єкт
        if response.parsed:
            # Перетворюємо об'єкти Pydantic у звичайні словники, як це було раніше
            replies = [{"bot_id": r.bot_id, "text": r.text} for r in response.parsed.replies]
            new_facts = response.parsed.new_facts
            scene_goal_reached = response.parsed.scene_goal_reached
            
            for fact in new_facts:
                await save_fact(db, chat_id, fact)
                print(f"[{chat_id}] МЕНТАЛЬНИЙ ЗАПИС: {fact}")
                
            return replies, scene_goal_reached
        else:
            return [], False
            
    except Exception as e:
        print(f"Помилка обробки відмови ШІ: {e}")
        return [], False

# 2. Оновлюємо функцію збереження (використовуємо INSERT OR IGNORE)
async def save_message(db: aiosqlite.Connection, chat_id: int, message_id: int, sender: str, text: str):
    await db.execute(
        "INSERT OR IGNORE INTO messages (chat_id, message_id, sender, text) VALUES (?, ?, ?, ?)",
        (chat_id, message_id, sender, text)
    )
    await db.commit()


@dp.message(Command(commands=["start_story", "start_story@tgTeller_bot"], ignore_mention=True))
async def handle_start(message: Message, bot: Bot):
    if bot.id != bot1.id:
        return

    chat_id = message.chat.id
    if not message.text:
        return

    # 1. Повноцінний вступ для гравця
    intro_text = (
        "🎓 *АКАДЕМІЯ СВЯТОГО ЮДИ* 🎓\n\n"
        "Ви — нова учениця в елітній закритій школі. Завтра ваш перший день. "
        "Раптом ваш телефон вібрує. Хтось анонімно додав вас у приватний чат...\n\n"
        "*(Системне повідомлення: Користувач '<span class=\"tg-spoiler\">ㅤㅤㅤㅤㅤㅤ</span>' додав вас до групи 'Еліта Юди')*"
    )
    
    await teller.send_message(chat_id, intro_text, parse_mode="html")
    await asyncio.sleep(3)
    
    # ВІДКРИВАЄМО БАЗУ ДЛЯ ЗБЕРЕЖЕННЯ ПОВІДОМЛЕНЬ ПРИ СТАРТІ
    async with aiosqlite.connect("chat_history.db") as db:
        # 2. Боти починають реагувати на появу новенької
        kai_msg = await bot1.send_message(chat_id, "Гей, хтось щойно додав сюди новий контакт. Це та сама новенька, що перевелася до нас? Привіт, як звати?) 👋 Я Кай.")
        await save_message(db, chat_id, kai_msg.message_id, f"bot_{bot1.id}", kai_msg.text)
        
        await asyncio.sleep(3)
        
        dorian_msg = await bot2.send_message(chat_id, "Кай, ти як завжди радієш усім підряд. <span class=\"tg-spoiler\">ㅤㅤㅤㅤㅤㅤ</span> знову грає в свої ігри. Дівчино, хто б ти не була, краще вийди з цього чату, поки можеш.", parse_mode="html")
        await save_message(db, chat_id, dorian_msg.message_id, f"bot_{bot2.id}", dorian_msg.text)
        
        await save_fact(db, chat_id, "Новенька в Академії, завтра перший день")


@dp.message(Command("reset", ignore_mention=True))
async def reset_game(message: Message):
    chat_id = message.chat.id
    async with aiosqlite.connect("chat_history.db") as db:
        # Видаляємо всі повідомлення, факти та статус глави для цього чату
        await db.execute("DELETE FROM messages WHERE chat_id = ?", (chat_id,))
        await db.execute("DELETE FROM memories WHERE chat_id = ?", (chat_id,))
        await db.execute("DELETE FROM chat_states WHERE chat_id = ?", (chat_id,))
        await db.commit()
        
    await message.answer("🔄 Системне повідомлення: Вашу пам'ять та прогрес повністю стерто. Введіть /start_story, щоб почати нову гру.")
    print(f"[{chat_id}] ПРОГРЕС СКИДАННЯ")

# 3. Оновлюємо хендлер: додаємо параметр bot: Bot
@dp.message()
async def handle_message(message: Message, bot: Bot):
    if bot.id != bot1.id:
        return

    chat_id = message.chat.id
    if not message.text:
        return

    # Обробка Reply (на що саме відповідає юзер)
    actual_text = message.text
    if message.reply_to_message and message.reply_to_message.text:
        replied_text = message.reply_to_message.text[:50] + "..."
        reply_user_id = message.reply_to_message.from_user.id
        
        # Визначаємо, кому саме відповіла дівчина
        if reply_user_id == bot1.id:
            reply_target = "Кая"
        elif reply_user_id == bot2.id:
            reply_target = "Доріана"
        elif reply_user_id == bot3.id:
            reply_target = "Люціана"
        elif reply_user_id == teller.id:
            reply_target = "Оповідача"
        else:
            reply_target = "когось"

        actual_text = f"{message.text} (Примітка: це пряма відповідь на повідомлення від {reply_target}: '{replied_text}')"

    sender = f"bot_{message.from_user.id}" if message.from_user.is_bot else "user"
    
    async with aiosqlite.connect("chat_history.db") as db:
        await save_message(db, chat_id, message.message_id, sender, actual_text)
        
        if sender == "user":
            await bot1.send_chat_action(chat_id=chat_id, action="typing")
            
            # Передаємо db у ШІ генератор
            ai_replies, scene_goal_reached = await generate_and_send_response(db, chat_id, bot1.id, bot2.id, bot3.id)
            
            if ai_replies:
                ai_replies = ai_replies
                
                for reply in ai_replies:
                    ai_sender = reply.get("bot_id")
                    ai_text = reply.get("text")
                    
                    typing_time = min(max(len(ai_text) / 30, 1), 3)
                    
                    if str(bot1.id) in ai_sender:
                        await bot1.send_chat_action(chat_id=chat_id, action="typing")
                        await asyncio.sleep(typing_time)
                        sent_msg = await bot1.send_message(chat_id, ai_text)
                        await save_message(db, chat_id, sent_msg.message_id, f"bot_{bot1.id}", ai_text)
                        
                    # ПОВЕРТАЄМО ЛОГІКУ ДЛЯ ДОРІАНА (bot2) ТА ЛЮЦІАНА (bot3)
                    elif str(bot2.id) in ai_sender:
                        await bot2.send_chat_action(chat_id=chat_id, action="typing")
                        await asyncio.sleep(typing_time)
                        sent_msg = await bot2.send_message(chat_id, ai_text)
                        await save_message(db, chat_id, sent_msg.message_id, f"bot_{bot2.id}", ai_text)
                        
                    elif str(bot3.id) in ai_sender:
                        await bot3.send_chat_action(chat_id=chat_id, action="typing")
                        await asyncio.sleep(typing_time)
                        sent_msg = await bot3.send_message(chat_id, ai_text)
                        await save_message(db, chat_id, sent_msg.message_id, f"bot_{bot3.id}", ai_text)

                # === ПЕРЕВІРКА СЦЕНИ ===
                if scene_goal_reached:
                    current_stage = await get_chat_stage(db, chat_id)
                    next_stage = current_stage + 1
                    
                    if next_stage in STORY_STAGES:
                        await asyncio.sleep(4)
                        intro_text = STORY_STAGES[current_stage]["next_scene_intro"]
                        await teller.send_message(chat_id, intro_text)
                        await advance_chat_stage(db, chat_id)
                        
                        # Пам'ятайте про унікальний від'ємний ID для системних повідомлень, як обговорювалось в попередньому пункті!
                        system_msg_id = int(time.time() * -1000)
                        await save_message(db, chat_id, system_msg_id, "system", intro_text) 
                        print(f"[{chat_id}] СЮЖЕТ ПЕРЕЙШОВ НА ГЛАВУ {next_stage}")
                    else:
                        # СЮЖЕТ ЗАКІНЧИВСЯ!
                        await asyncio.sleep(4)
                        end_text = (
                            "🎬 *КІНЕЦЬ ДЕМО-ВЕРСІЇ* 🎬\n\n"
                            "Дякуємо, що зіграли в перший епізод 'Академії Святого Юди'. "
                            "Попереду ще багато таємниць. Введіть /reset, щоб спробувати інші варіанти діалогів!"
                        )
                        await teller.send_message(chat_id, end_text)
                        # Можна також заблокувати подальші відповіді ботів, але для демо вистачить і цього.
            else:
                await teller.send_message(chat_id, "*(Зв'язок з Академією тимчасово перервано. Спробуйте ще раз.)*")
                return

async def main():
    await init_db()
    await dp.start_polling(bot1, bot2, bot3)

if __name__ == "__main__":
    asyncio.run(main())